{
    admin off
    email {$CONTEXT_RELAY_ACME_EMAIL}
    servers {
        protocols h1 h2
    }
}

{$CONTEXT_RELAY_DOMAIN} {
    encode zstd gzip

    @allowed path /healthz /v1/register /v1/poll/* /v1/result/* /t/*/image/*
    handle @allowed {
        reverse_proxy relay:8080
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    header {
        -Server
        -Via
        Strict-Transport-Security "max-age=31536000"
        Cache-Control "no-store"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    log {
        output discard
    }
}
